          "_name": "features1",
          "_sourceTheme": "mobirise4",
          "_customHTML": "<section class=\"features1\" group=\"Features\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"9\" step=\"1\" value=\"0\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"9\" step=\"1\" value=\"0\">\n\n        <input type=\"checkbox\" title=\"Show Title\" name=\"showTitle\">\n        <input type=\"checkbox\" title=\"Show Text\" name=\"showText\">\n        <select title=\"Cards\" name=\"cardsAmount\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\" selected>4</option>\n        </select>\n\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Background Image\" value=\"@PROJECT_PATH@/assets/images/3d-render-modern-background-with-plexus-design-2000x1500.webp\">\n            <input type=\"color\" title=\"Background Color\" value=\"#57aa05\" selected>\n            <input type=\"video\" title=\"Background Video\" value=\"https://www.youtube.com/watch?v=36YgDDJ7XSc\">\n        </fieldset>\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#333333\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n        <!-- End block parameters -->\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\"></div>\n        <div class=\"container\">\n            <div class=\"media-container-row\">\n                <div class=\"card p-3 col-12 col-md-4 col-lg-3\">\n                    <div class=\"card-box bg-light border border-success rounded-lg\" style=\"width: 100%; height: 9rem;\">\n                        <div class=\"card-img pb-\">\n                            [JS_CODE_0]\n                            <lord-icon src=\"https://cdn.lordicon.com/kxockqqi.json\" trigger=\"hover\" stroke=\"30\" target=\".card-box\" colors=\"primary:#545454,secondary:#16c72e,tertiary:#0816A8,quaternary:#2CA808\" style=\"width: 80px; height: 80px;\">\n                            </lord-icon>\n                            <h3 class=\"card-title py-3 mbr-fonts-style display-6\">\n                                <a href=\"page7.html\">Segunda via</a>\n                            </h3>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"card p-3 col-12 col-md-4 col-lg-3\">\n                    <div class=\"card-box bg-light border border-success rounded-lg\" style=\"width: 100%; height: 9rem;\">\n                        <div class=\"card-img pb-\">\n                            [JS_CODE_1]\n                            <lord-icon src=\"https://cdn.lordicon.com/wzrwaorf.json\" trigger=\"hover\" state=\"hover-conversation-alt\" stroke=\"30\" target=\".card-box\" colors=\"primary:#545454,secondary:#16c72e,tertiary:#0816A8,quaternary:#2CA808\" style=\"width: 80px; height: 80px;\">\n                            </lord-icon>\n                            <h3 class=\"card-title py-3 mbr-fonts-style display-6\">\n                                <a href=\"page7.html\">Suporte</a>\n                            </h3>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"card p-3 col-12 col-md-4 col-lg-3\">\n                    <div class=\"card-box bg-light border border-success rounded-lg\" style=\"width: 100%; height: 9rem;\">\n                        <div class=\"card-img pb-\">\n                            [JS_CODE_2]\n                            <lord-icon src=\"https://cdn.lordicon.com/ghhwiltn.json\" trigger=\"hover\" stroke=\"30\" target=\".card-box\" colors=\"primary:#545454,secondary:#16c72e,tertiary:#0816A8,quaternary:#2CA808\" style=\"width: 80px; height: 80px;\">\n                            </lord-icon>\n                            <h3 class=\"card-title py-3 mbr-fonts-style display-6\">\n                                <a href=\"page7.html\">Contratar</a>\n                            </h3>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"card p-3 col-12 col-md-4 col-lg-3\">\n                    <div class=\"card-box bg-light border border-success rounded-lg\" style=\"width: 100%; height: 9rem;\">\n                        <div class=\"card-img pb-\">\n                            [JS_CODE_3]\n                            <lord-icon src=\"https://cdn.lordicon.com/dgpphngr.json\" trigger=\"hover\" stroke=\"30\" target=\".card-box\" colors=\"primary:#545454,secondary:#16c72e,tertiary:#0816A8,quaternary:#2CA808\" style=\"width: 80px; height: 80px;\">\n                            </lord-icon>\n                            <h3 class=\"card-title py-3 mbr-fonts-style display-6\">\n                                <a href=\"page7.html\">SpeedTest</a>\n                            </h3>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n</section>",
